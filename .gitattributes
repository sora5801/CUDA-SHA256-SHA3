# Normalize line endings so the repo is consistent across Windows and Linux.
# Text files are stored with LF in the repository; Git converts to the native
# style on checkout. This keeps the CMake/Linux build and the Windows build
# working from the same sources without spurious diffs.
* text=auto

# Source and docs are always LF in the repo.
*.cu    text eol=lf
*.cpp   text eol=lf
*.h     text eol=lf
*.cuh   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf

# Visual Studio project files and Windows scripts use CRLF (their native form).
*.sln     text eol=crlf
*.vcxproj text eol=crlf
*.filters text eol=crlf
*.bat     text eol=crlf
*.ps1     text eol=crlf
